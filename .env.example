# Google Apps Script deployed URL
NEXT_PUBLIC_APPS_SCRIPT_URL=

# Google Calendar Service Account JSON (single-line JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Google Calendar ID (usually your Gmail address)
GOOGLE_CALENDAR_ID=mydigitalcareer.support@gmail.com

# Admin credentials (server-only — never use NEXT_PUBLIC_ prefix)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
