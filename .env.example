# ═══════════════════════════════════════════════════════════
# My Digital Career — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════

# ── Google Service Account ─────────────────────────────────
# Paste the entire Service Account JSON as a single line.
# This account needs access to both Google Calendar AND Google Sheets.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Google Calendar ────────────────────────────────────────
# IMPORTANT: use the explicit shared calendar ID.
# Do not rely on "primary" with a service account.
GOOGLE_CALENDAR_ID=

# ── Google Sheets (e-CV) ───────────────────────────────────
# The spreadsheet ID from the Google Sheets URL
# (the long string between /d/ and /edit in the URL)
GOOGLE_SPREADSHEET_ID=

# ── Google Sheets (Solutions Pro — separate file) ──────────
# Create a new Google Sheet named "Demandes devis - Solutions Pro".
# Share it with your service account email (same as above).
# Copy the spreadsheet ID and paste it here.
# Used exclusively for professional quote requests from /solutions-pro.
# ⚠️  Keep this SEPARATE from GOOGLE_SPREADSHEET_ID (e-CV data must not mix).
PRO_QUOTES_SHEET_ID=

# ── Google Apps Script (emails + legacy fallback) ──────────
# Use the latest published /exec deployment URL.
# If you publish a new Apps Script version, update this value as well.
GOOGLE_APPS_SCRIPT_URL=

# Client-side legacy access (admin/contact/chat compatibility)
# Keep this aligned with GOOGLE_APPS_SCRIPT_URL when still used in the browser.
NEXT_PUBLIC_APPS_SCRIPT_URL=

# ── Authentication ─────────────────────────────────────────
# JWT secret for client tokens (min 32 random characters)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# ── Admin credentials (server-only) ───────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=

# ── Discord Webhooks ───────────────────────────────────────
# Create webhooks in Discord Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_NOTIFICATIONS=
DISCORD_WEBHOOK_QUESTIONNAIRES=
DISCORD_WEBHOOK_CHAT=

# ── Stripe (future — not yet active) ──────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Google Analytics ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=
